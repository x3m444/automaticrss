# cp .env.example .env  →  completează și pornește cu: docker compose up -d

# ── Baza de date Supabase ──────────────────────────────────────────────────────
DB_HOST=db.xxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_supabase_password

# ── Transmission (rulează în același container → localhost) ───────────────────
TR_PORT=9091          # portul expus pe host
TR_USER=              # lasă gol dacă nu vrei autentificare RPC
TR_PASS=

# ── Jackett (opțional) ─────────────────────────────────────────────────────────
JACKETT_PORT=9117
# JACKETT_API_KEY=    # completezi după prima pornire din http://localhost:9117

# ── Aplicație ──────────────────────────────────────────────────────────────────
APP_PORT=8080
TZ=Europe/Bucharest
